{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "artifact_kind": {
      "const": "repaired_skill_readiness"
    },
    "artifact_version": {
      "type": "string"
    },
    "catalog_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "evidence": {
      "additionalProperties": true,
      "required": [
        "artifact_paths",
        "citations_or_paths"
      ],
      "type": "object"
    },
    "independence": {
      "additionalProperties": true,
      "required": [
        "task_defined_outside_skill",
        "evaluator_defined_outside_skill",
        "expected_result_defined_outside_skill",
        "uses_exact_skill_content_for_expected_result"
      ],
      "type": "object"
    },
    "input_snapshot": {
      "additionalProperties": true,
      "required": [
        "kind",
        "identifier",
        "is_real",
        "original_runtime_artifact",
        "original_mirrored_path",
        "repaired_path"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": true,
      "required": [
        "checks_passed",
        "checks_total",
        "score_percent",
        "benchmark_verdict",
        "blocking_failure_count"
      ],
      "type": "object"
    },
    "outputs": {
      "additionalProperties": true,
      "required": [
        "path",
        "repair_record_path",
        "result_sha256",
        "repair_sha256",
        "schema"
      ],
      "type": "object"
    },
    "runner": {
      "additionalProperties": true,
      "required": [
        "timestamp_utc",
        "tool",
        "model_or_runtime",
        "run_name"
      ],
      "type": "object"
    }
  },
  "required": [
    "artifact_version",
    "artifact_kind",
    "skill_id",
    "scenario_id",
    "catalog_commit",
    "source_commit",
    "source_repo",
    "source_path",
    "runner",
    "input_snapshot",
    "execution",
    "outputs",
    "metrics",
    "independence",
    "evidence",
    "objective_checks"
  ],
  "type": "object"
}
